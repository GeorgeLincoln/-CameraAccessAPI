{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Error",
      "CameraAccessAPI": "Information",
      "CameraAccessAPI.Infrastructure.Security": "Information"
    }
  },
  "AllowedHosts": "localhost,api.yourdomain.com",
  "Jwt": {
    "Key": "${JWT_SECRET_KEY}",
    "Issuer": "CameraAccessAPI",
    "Audience": "CameraClients",
    "ExpiryMinutes": 30,
    "AllowInsecureHttp": false
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "IpWhitelist": [],
    "EndpointWhitelist": [],
    "ClientWhitelist": [],
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      },
      {
        "Endpoint": "/api/auth/login",
        "Period": "5m",
        "Limit": 3
      }
    ]
  }
}
